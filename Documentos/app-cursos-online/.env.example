# ===== CourseForge AI — Variables de Entorno =====
# Ver backend/.env.example y apps/web/.env.local para configuración específica

# ─── Backend (Railway) ─────────────────────────────────────────
# DATABASE_URL → backend/.env
# JWT_SECRET → backend/.env

# ─── Frontend (Vercel) ─────────────────────────────────────────
# NEXT_PUBLIC_API_URL → apps/web/.env.local

# ─── Servicios IA (Fase 2+) ────────────────────────────────────
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
HEYGEN_API_KEY=
DID_API_KEY=

# ─── Pagos (Fase 2+) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=

# ─── Email (Fase 2+) ──────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@courseforge.com

# ─── Video Hosting (Fase 2+) ──────────────────────────────────
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# ─── Redis/BullMQ (Fase 2+) ───────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

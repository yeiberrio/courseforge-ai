# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5441/courseforge?schema=public"

# JWT
JWT_SECRET="cambiar-este-secreto-en-produccion"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# App
PORT=3000
NODE_ENV=development

# Supabase Storage (for persistent video/audio storage)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"
SUPABASE_BUCKET="course-videos"
